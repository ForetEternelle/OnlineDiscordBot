# ==========================================
#        DISCORD BOT CONFIGURATION
# ==========================================

# Display name used in embeds and footer.
DISCORD_BOT_NAME='PSDK Bot'

# Bot version displayed by /about.
DISCORD_BOT_VERSION=1.0

# Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# Discord application client ID from the Discord Developer Portal.
DISCORD_CLIENT_ID=

# Discord logs channel ID where the bot should send logs.
DISCORD_LOGS_CHANNEL_ID=1423044423083753504


# ==========================================
#       ONLINE SERVER API SETTINGS
# ==========================================

# Base URL of the Online Server (https://github.com/PokemonWorkshop/OnlineServer) API (example: https://online.example.com/api).
ONLINE_SERVER_API_URL=

# Bearer token used to authenticate against the Online Server API.
ONLINE_SERVER_BEARER_TOKEN=


# ==========================================
#        DATA & ASSETS DIRECTORIES
# ==========================================

# Base URL of the Data API (example: https://data.example.com/api).
DATA_API_BASE_URL=

# Base URL for Pokemon sprite/image files.
POKEMON_IMAGE_BASE_URL=